@{
    ViewData["Title"] = "About";
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/about_style.css">

<!-- VIDEO BACKGROUND -->
<div class="video-background">
    <video autoplay muted loop id="bg-video">
        <source src="~/bgvideo.mp4" type="video/mp4">
    </video>
</div>


<!-- MAIN CONTENT -->
<div class="main-content">
    <div class="about">
        <h2>About Cebu Eastern College</h2>

        <p>
            Cebu Eastern College is a private educational institution committed to providing
            quality education and developing responsible, skilled, and globally competitive individuals.
        </p>

        <h3>Mission</h3>
        <p>
            To provide students with knowledge, skills, and values that prepare them
            for future careers and lifelong success.
        </p>

        <h3>Vision</h3>
        <p>
            To become a leading institution recognized for excellence in education,
            innovation, and community service.
        </p>
    </div>
</div>

