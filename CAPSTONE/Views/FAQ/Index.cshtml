@model List<CAPSTONE.Models.FAQ>

@{
    Layout = "_Layout";
    ViewData["Title"] = "FAQ";

    var selectedCategory = Context.Request.Query["category"].ToString();
}

<link rel="stylesheet" href="~/css/inquiry_style.css">

<!-- CATEGORY FILTER ONLY -->
<form method="get" id="filterForm" class="controls">

    <select name="category" id="categorySelect"
            onchange="document.getElementById('filterForm').submit();">

        <option value="All" selected="@(string.IsNullOrEmpty(selectedCategory) || selectedCategory == "All")">
            All Categories
        </option>

        <option value="Enrollment" selected="@(selectedCategory == "Enrollment")">
            Enrollment
        </option>

        <option value="Academics" selected="@(selectedCategory == "Academics")">
            Academics
        </option>

        <option value="Facilities" selected="@(selectedCategory == "Facilities")">
            Facilities
        </option>

        <option value="Support" selected="@(selectedCategory == "Support")">
            Support
        </option>

        <option value="Finance" selected="@(selectedCategory == "Finance")">
            Finance
        </option>

        <option value="General" selected="@(selectedCategory == "General")">
            General
        </option>

    </select>

</form>

<!-- FAQ LIST -->
<div class="faq-container">
    @if (Model.Count == 0)
    {
        <p style="text-align:center; color:white;">No results found.</p>
    }
    else
    {
        @foreach (var item in Model)
        {
            <div class="faq-item">
                <h3>@item.Question</h3>
                <p style="display:none;">@item.Answer</p>
            </div>
        }
    }
</div>

<!-- JS -->
<script src="~/js/faq.js"></script>